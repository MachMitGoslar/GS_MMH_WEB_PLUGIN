{
  "name": "gs-mmh-web-plugin",
  "version": "1.0.0",
  "description": "Custom Kirby plugin for MachMit!Haus Goslar website",
  "scripts": {
    "dev": "kirbyup serve src/index.js",
    "build": "kirbyup src/index.js",
    "format": "prettier --write \"src/**/*.{js,vue}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue}\"",
    "lint": "npm run format:check",
    "pre-push": "npm run lint && npm run build",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "kirbyup": "^3.1.3",
    "prettier": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MachMitGoslar/GS_MMH_WEB_PLUGIN.git"
  },
  "author": "MachMit!Haus Goslar",
  "license": "MIT"
}
